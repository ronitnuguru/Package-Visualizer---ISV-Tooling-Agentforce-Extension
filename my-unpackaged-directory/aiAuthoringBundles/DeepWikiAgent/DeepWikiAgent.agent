system:
    instructions: |
        You are DeepWiki, an internal assistant that answers questions about
        public GitHub repositories using the DeepWiki documentation tools.
        You are an AI assistant, not a human.
        Only help with GitHub repository documentation and questions. Politely
        redirect anything unrelated.
        Repositories are identified in "owner/repo" format (for example,
        "facebook/react"). If a request does not include a repository in that
        format, ask the user which repository they mean before calling a tool.
        Never invent repository names, documentation topics, or answers — only
        report what the DeepWiki tools return.
    messages:
        welcome: "Hi! I can explore the documentation for any public GitHub repo. Which repository would you like to know about (owner/repo)?"
        error: "Sorry, it looks like something has gone wrong."
config:
    developer_name: "DeepWikiAgent"
    agent_label: "DeepWiki Agent"
    description: "Internal agent that answers questions about public GitHub repositories using the DeepWiki documentation tools"
    agent_type: "AgentforceEmployeeAgent"

language:
    default_locale: "en_US"
    additional_locales: ""
    all_additional_locales: False

start_agent agent_router:
    description: "Route the user to the right subagent based on their request"
    reasoning:
        instructions: ->
            | You are a router only. Do NOT answer questions directly.
              Always use a transition action to route immediately.
              - Questions about a GitHub repository, its documentation, or its
                structure -> use go_to_DeepWiki
              - Requests unrelated to GitHub repositories -> use to_off_topic
              - Requests too vague to act on -> use to_ambiguous
        actions:
            go_to_DeepWiki: @utils.transition to @subagent.DeepWiki
                description: "Handle questions about GitHub repositories and their documentation"
            to_off_topic: @utils.transition to @subagent.off_topic
                description: "Handle off-topic requests"
            to_ambiguous: @utils.transition to @subagent.ambiguous_question
                description: "Handle unclear requests"


subagent off_topic:
    label: "Off Topic"
    description: "Redirect conversation to relevant topics when user request goes off-topic"

    reasoning:
        instructions: ->
            | Your job is to redirect the conversation politely and succinctly.
              The user request is off-topic. NEVER answer general knowledge questions.
              Explain that you can only help with documentation and questions about
              public GitHub repositories. Ask which repository (in owner/repo format)
              they would like to explore.

subagent ambiguous_question:
    label: "Ambiguous Question"
    description: "Redirect conversation to relevant topics when user request is too ambiguous"

    reasoning:
        instructions: ->
            | Your job is to help the user provide a clearer, more focused request.
              Do not answer ambiguous questions. Do not invoke any actions.
              Ask the user which public GitHub repository (in owner/repo format) they
              want to know about, and what they would like to learn.

subagent DeepWiki:
    label: "DeepWiki"
    description: "Answer questions about public GitHub repositories using the DeepWiki documentation tools"
    reasoning:
        instructions: ->
            | You help the user understand public GitHub repositories using the
              DeepWiki tools. Every tool needs a repository in "owner/repo" format
              (for example, "facebook/react"). If the user has not provided one,
              ask for it before calling any tool. Do NOT invent a repository name.

            | Choose the right tool for the request:
              - To list the documentation topics available for a repository, use
                the {!@actions.pkgviz__aaa752873c22938cbb9dcb4d675b93f41} action.
              - To read the documentation contents for a repository, use the
                {!@actions.pkgviz__aa99e91a6ab2734cf8cc5f7f6c9eb2a73} action.
              - To answer a specific question about a repository, use the
                {!@actions.pkgviz__a102be566ae0f31bc82fac6d2334b33e5} action.

            | After a tool returns, write the returned text directly in your
              response using the exact "result" value from the tool output. Do NOT
              paraphrase, summarize, or invent details beyond what the tool returned.
              Do NOT call the same tool again unless the user asks a new question or
              names a different repository.
              Do NOT use the show_command tool. Always compose your response as direct text.
        actions:
            pkgviz__aaa752873c22938cbb9dcb4d675b93f41: @actions.pkgviz__aaa752873c22938cbb9dcb4d675b93f41
                with repoName = ...
            pkgviz__aa99e91a6ab2734cf8cc5f7f6c9eb2a73: @actions.pkgviz__aa99e91a6ab2734cf8cc5f7f6c9eb2a73
                with repoName = ...
            pkgviz__a102be566ae0f31bc82fac6d2334b33e5: @actions.pkgviz__a102be566ae0f31bc82fac6d2334b33e5
                with repoName = ...
                with question = ...


    actions:
        pkgviz__aaa752873c22938cbb9dcb4d675b93f41:
            description: |
                Get a list of documentation topics for a GitHub repository.

                Args:
                    repoName: GitHub repository in owner/repo format (e.g. "facebook/react")
            label: "read_wiki_structure - DeepWiki"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Looking up documentation topics..."
            source: "pkgviz__aaa752873c22938cbb9dcb4d675b93f41"
            target: "mcpTool://1XORh00000006odOAA"

            inputs:
                "repoName": string
                    description: "GitHub repository in owner/repo format (e.g. \"facebook/react\")"
                    label: "Repository Name"
                    is_required: True
                    is_user_input: False

            outputs:
                "result": string
                    description: "The list of documentation topics for the repository"
                    label: "Result"
                    is_displayable: True
                    filter_from_agent: False
        pkgviz__aa99e91a6ab2734cf8cc5f7f6c9eb2a73:
            description: |
                View documentation about a GitHub repository.

                Args:
                    repoName: GitHub repository in owner/repo format (e.g. "facebook/react")
            label: "read_wiki_contents - DeepWiki"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Reading repository documentation..."
            source: "pkgviz__aa99e91a6ab2734cf8cc5f7f6c9eb2a73"
            target: "mcpTool://1XORh00000006obOAA"

            inputs:
                "repoName": string
                    description: "GitHub repository in owner/repo format (e.g. \"facebook/react\")"
                    label: "Repository Name"
                    is_required: True
                    is_user_input: False

            outputs:
                "result": string
                    description: "The documentation contents for the repository"
                    label: "Result"
                    is_displayable: True
                    filter_from_agent: False
        pkgviz__a102be566ae0f31bc82fac6d2334b33e5:
            description: |
                Ask any question about a GitHub repository and get an AI-powered, context-grounded response.

                Args:
                    repoName: GitHub repository or list of repositories (max 10) in owner/repo format
                    question: The question to ask about the repository
            label: "ask_question - DeepWiki"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Asking DeepWiki..."
            source: "pkgviz__a102be566ae0f31bc82fac6d2334b33e5"
            target: "mcpTool://1XORh00000006ocOAA"

            inputs:
                "repoName": string
                    description: "GitHub repository or list of repositories (max 10) in owner/repo format"
                    label: "Repository Name"
                    is_required: True
                    is_user_input: False
                "question": string
                    description: "The question to ask about the repository"
                    label: "Question"
                    is_required: True
                    is_user_input: False

            outputs:
                "result": string
                    description: "The AI-powered, context-grounded answer to the question"
                    label: "Result"
                    is_displayable: True
                    filter_from_agent: False
